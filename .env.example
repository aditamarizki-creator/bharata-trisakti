# ===== Bharata Trisakti — environment vars =====

# WAJIB: secret untuk JWT cookie session admin (random 32+ chars)
JWT_SECRET=ganti-dengan-string-random-32-karakter-atau-lebih

# WAJIB: bcrypt hash dari password admin (jangan plain text!)
# Generate via: node -e "require('bcryptjs').hash('PasswordAnda', 10).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$10$contoh.bcrypt.hash.disini

# Opsional: lokasi data JSON (default ./data)
DATA_DIR=/var/www/bharata/data

# Opsional: lokasi upload foto (default ./public/uploads)
UPLOAD_DIR=/var/www/bharata/uploads
UPLOAD_PUBLIC_PREFIX=/uploads

# Opsional: Vercel KV / Upstash Redis (kalau set, override filesystem)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Opsional: Vercel Blob (kalau set, override filesystem upload)
# BLOB_READ_WRITE_TOKEN=
